# =============================================================================
# HiveSchool Leaderboard Portal — Environment Variables (Template)
# =============================================================================
# Copy this file to `.env.local` (for local dev) and fill in the values from
# your Supabase project dashboard:  Project Settings → API
# -----------------------------------------------------------------------------

# --- Public (exposed to the browser — safe, protected by RLS) -----------------
# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (publishable). RLS policies enforce access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Server-only (NEVER expose to the browser) --------------------------------
# Service-role key. Bypasses RLS. Used only by the seed script and trusted
# server-side admin operations. Keep this secret. Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Admin bootstrap (used by the seed script to create the admin account) ----
# The seed script creates this Supabase Auth user. Credentials are never
# hardcoded in the frontend; the password is hashed by Supabase Auth.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password

# --- App ---------------------------------------------------------------------
# Public base URL of the deployed app (used for absolute links / metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

